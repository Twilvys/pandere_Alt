generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model achievement_log {
  id             Int       @id(map: "pk_achievement_log") @default(autoincrement())
  indicator_id   Int
  value_achieved Decimal   @db.Decimal(12, 4)
  date           DateTime  @default(dbgenerated("CURRENT_DATE")) @db.Date
  evidence_url   String?   @db.VarChar(512)
  indicator      indicator @relation(fields: [indicator_id], references: [id], onDelete: Cascade, map: "fk_achievement_indicator")

  @@index([indicator_id], map: "idx_achievement_log_indicator")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model actor {
  id         Int         @id(map: "pk_actor") @default(autoincrement())
  email      String?     @unique(map: "uq_actor_email") @db.VarChar(255)
  actor_type String?     @db.VarChar(10)
  is_active  Boolean     @default(true)
  deleted_at DateTime?   @db.Timestamptz(6)
  address    address[]
  donor      donor?
  enterprise enterprise?
  person     person?
  staff      staff?
  telephone  telephone[]
  users      users?
  volunteer  volunteer?
}

model address {
  actor_id    Int
  location_id Int
  type        String?  @db.VarChar(50)
  actor       actor    @relation(fields: [actor_id], references: [id], onDelete: Cascade, map: "fk_address_actor")
  location    location @relation(fields: [location_id], references: [id], map: "fk_address_location")

  @@id([actor_id, location_id], map: "pk_address")
  @@index([location_id], map: "idx_address_location")
}

model allowed_transitions {
  from_status_id                                    Int
  to_status_id                                      Int
  status_allowed_transitions_from_status_idTostatus status @relation("allowed_transitions_from_status_idTostatus", fields: [from_status_id], references: [id], onDelete: Cascade, map: "fk_transitions_from")
  status_allowed_transitions_to_status_idTostatus   status @relation("allowed_transitions_to_status_idTostatus", fields: [to_status_id], references: [id], onDelete: Cascade, map: "fk_transitions_to")

  @@id([from_status_id, to_status_id], map: "pk_allowed_transitions")
  @@index([to_status_id], map: "idx_transitions_to")
}

model audit_log {
  id         Int      @id(map: "pk_audit_log") @default(autoincrement())
  user_id    Int
  table_name String   @db.VarChar(100)
  record_id  Int
  action     String   @db.VarChar(50)
  old_value  Json?
  new_value  Json?
  timestamp  DateTime @default(now()) @db.Timestamptz(6)
  users      users    @relation(fields: [user_id], references: [id], map: "fk_audit_log_user")

  @@index([user_id], map: "idx_audit_log_user")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model budget_allocation {
  id         Int     @id(map: "pk_budget_allocation") @default(autoincrement())
  project_id Int
  amount     Decimal @default(0.0000) @db.Decimal(19, 4)
  project    project @relation(fields: [project_id], references: [id], onDelete: Cascade, map: "fk_budget_alloc_project")

  @@index([project_id], map: "idx_budget_alloc_project")
}

model currency {
  id               Int        @id(map: "pk_currency") @default(autoincrement())
  name             String     @unique(map: "uq_currency_name") @db.VarChar(50)
  value_in_dollars Decimal    @db.Decimal(12, 6)
  donation         donation[]
  fund             fund[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model donation {
  id                Int                 @id(map: "pk_donation") @default(autoincrement())
  donor_id          Int
  project_id        Int
  currency_id       Int
  amount            Decimal             @db.Decimal(19, 4)
  date              DateTime            @default(now()) @db.Timestamptz(6)
  is_restricted     Boolean             @default(false)
  is_active         Boolean             @default(true)
  deleted_at        DateTime?           @db.Timestamptz(6)
  currency          currency            @relation(fields: [currency_id], references: [id], map: "fk_donation_currency")
  donor             donor               @relation(fields: [donor_id], references: [id], map: "fk_donation_donor")
  project           project             @relation(fields: [project_id], references: [id], map: "fk_donation_project")
  fund_has_donation fund_has_donation[]

  @@index([currency_id], map: "idx_donation_currency")
  @@index([donor_id], map: "idx_donation_donor")
  @@index([project_id], map: "idx_donation_project")
}

model donor {
  id       Int        @id(map: "pk_donor") @default(autoincrement())
  actor_id Int        @unique(map: "uq_donor_actor")
  type     String     @db.VarChar(10)
  donation donation[]
  actor    actor      @relation(fields: [actor_id], references: [id], onDelete: Cascade, map: "fk_donor_actor")
}

model enterprise {
  id                           Int                            @id(map: "pk_enterprise") @default(autoincrement())
  actor_id                     Int                            @unique(map: "uq_enterprise_actor")
  name                         String                         @db.VarChar(150)
  rtn                          String                         @unique(map: "uq_enterprise_rtn") @db.VarChar(20)
  business_sector              String?                        @db.VarChar(100)
  actor                        actor                          @relation(fields: [actor_id], references: [id], onDelete: Cascade, map: "fk_enterprise_actor")
  legal_representative_history legal_representative_history[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model expense {
  id          Int      @id(map: "pk_expense") @default(autoincrement())
  project_id  Int
  category    String   @db.VarChar(75)
  amount      Decimal  @default(0.0000) @db.Decimal(19, 4)
  date        DateTime @default(dbgenerated("CURRENT_DATE")) @db.Date
  receipt_url String?  @db.VarChar(512)
  project     project  @relation(fields: [project_id], references: [id], map: "fk_expense_project")

  @@index([project_id], map: "idx_expense_project")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model fund {
  id                Int                 @id(map: "pk_fund") @default(autoincrement())
  currency_id       Int
  amount            Decimal             @default(0.0000) @db.Decimal(19, 4)
  currency          currency            @relation(fields: [currency_id], references: [id], map: "fk_fund_currency")
  fund_has_donation fund_has_donation[]

  @@index([currency_id], map: "idx_fund_currency")
}

model fund_has_donation {
  fund_id     Int
  donation_id Int
  donation    donation @relation(fields: [donation_id], references: [id], onDelete: Cascade, map: "fk_fund_donation_donation")
  fund        fund     @relation(fields: [fund_id], references: [id], onDelete: Cascade, map: "fk_fund_donation_fund")

  @@id([fund_id, donation_id], map: "pk_fund_has_donation")
  @@index([donation_id], map: "idx_fund_donation_donation")
}

model indicator {
  id              Int               @id(map: "pk_indicator") @default(autoincrement())
  project_id      Int
  name            String            @db.VarChar(150)
  unit            String?           @db.VarChar(50)
  target_value    Decimal?          @db.Decimal(12, 4)
  achievement_log achievement_log[]
  project         project           @relation(fields: [project_id], references: [id], onDelete: Cascade, map: "fk_indicator_project")

  @@index([project_id], map: "idx_indicator_project")
}

model job_title {
  id                          Int                           @id(map: "pk_job_title") @default(autoincrement())
  organization_id             Int
  name                        String                        @db.VarChar(100)
  description                 String?                       @db.VarChar(255)
  organization                organization                  @relation(fields: [organization_id], references: [id], onDelete: Cascade, map: "fk_job_title_organization")
  staff_has_job_title_history staff_has_job_title_history[]

  @@index([organization_id], map: "idx_job_title_organization")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model legal_representative_history {
  person_id     Int
  enterprise_id Int
  start_date    DateTime   @default(dbgenerated("CURRENT_DATE")) @db.Date
  end_date      DateTime?  @db.Date
  enterprise    enterprise @relation(fields: [enterprise_id], references: [id], onDelete: Cascade, map: "fk_legal_rep_enterprise")
  person        person     @relation(fields: [person_id], references: [id], map: "fk_legal_rep_person")

  @@id([person_id, enterprise_id], map: "pk_legal_representative_history")
  @@index([enterprise_id], map: "idx_legal_rep_enterprise")
}

model location {
  id                 Int        @id(map: "pk_location") @default(autoincrement())
  name               String     @db.VarChar(100)
  parent_location_id Int?
  address            address[]
  location           location?  @relation("locationTolocation", fields: [parent_location_id], references: [id], map: "fk_location_parent")
  other_location     location[] @relation("locationTolocation")

  @@index([parent_location_id], map: "idx_location_parent")
}

model organization {
  id        Int         @id(map: "pk_organization") @default(autoincrement())
  name      String      @unique(map: "uq_organization_name") @db.VarChar(100)
  job_title job_title[]
}

model permission {
  id                  Int                   @id(map: "pk_permission") @default(autoincrement())
  slug                String                @unique(map: "uq_permission_slug") @db.VarChar(100)
  description         String?               @db.VarChar(255)
  role_has_permission role_has_permission[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model person {
  id                           Int                            @id(map: "pk_person") @default(autoincrement())
  actor_id                     Int                            @unique(map: "uq_person_actor")
  first_name                   String                         @db.VarChar(75)
  middle_name                  String?                        @db.VarChar(75)
  first_surname                String                         @db.VarChar(75)
  second_surname               String?                        @db.VarChar(75)
  birth_date                   DateTime                       @db.Date
  dni                          String                         @unique(map: "uq_person_dni") @db.VarChar(20)
  legal_representative_history legal_representative_history[]
  actor                        actor                          @relation(fields: [actor_id], references: [id], onDelete: Cascade, map: "fk_person_actor")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model project {
  id                  Int                   @id(map: "pk_project") @default(autoincrement())
  name                String                @db.VarChar(150)
  description         String?
  start_date          DateTime?             @db.Date
  end_date            DateTime?             @db.Date
  is_active           Boolean               @default(true)
  deleted_at          DateTime?             @db.Timestamptz(6)
  budget_allocation   budget_allocation[]
  donation            donation[]
  expense             expense[]
  indicator           indicator[]
  project_has_skill   project_has_skill[]
  project_has_status  project_has_status[]
  project_publication project_publication[]
  project_task        project_task[]
  work_log            work_log[]
}

model project_has_skill {
  project_id Int
  skill_id   Int
  project    project @relation(fields: [project_id], references: [id], onDelete: Cascade, map: "fk_proj_skills_project")
  skill      skill   @relation(fields: [skill_id], references: [id], onDelete: Cascade, map: "fk_proj_skills_skill")

  @@id([project_id, skill_id], map: "pk_project_has_skill")
  @@index([skill_id], map: "idx_proj_skills_skill")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model project_has_status {
  project_id Int
  status_id  Int
  start_date DateTime  @default(now()) @db.Timestamptz(6)
  end_date   DateTime? @db.Timestamptz(6)
  project    project   @relation(fields: [project_id], references: [id], onDelete: Cascade, map: "fk_project_status_project")
  status     status    @relation(fields: [status_id], references: [id], map: "fk_project_status_status")

  @@id([project_id, status_id, start_date], map: "pk_project_has_status")
  @@index([status_id], map: "idx_project_status_status")
}

model project_publication {
  id         Int      @id(map: "pk_project_publication") @default(autoincrement())
  project_id Int
  target     Decimal? @db.Decimal(19, 4)
  media_url  String?  @db.VarChar(512)
  project    project  @relation(fields: [project_id], references: [id], onDelete: Cascade, map: "fk_publication_project")

  @@index([project_id], map: "idx_publication_project")
}

model project_task {
  id         Int       @id(map: "pk_project_task") @default(autoincrement())
  project_id Int
  status_id  Int
  name       String    @db.VarChar(100)
  due_date   DateTime? @db.Date
  project    project   @relation(fields: [project_id], references: [id], onDelete: Cascade, map: "fk_task_project")
  status     status    @relation(fields: [status_id], references: [id], map: "fk_task_status")

  @@index([project_id], map: "idx_task_project")
  @@index([status_id], map: "idx_task_status")
}

model role {
  id                  Int                   @id(map: "pk_role") @default(autoincrement())
  name                String                @unique(map: "uq_role_name") @db.VarChar(50)
  role_has_permission role_has_permission[]
  users               users[]
}

model role_has_permission {
  role_id       Int
  permission_id Int
  permission    permission @relation(fields: [permission_id], references: [id], onDelete: Cascade, map: "fk_role_permission_permission")
  role          role       @relation(fields: [role_id], references: [id], onDelete: Cascade, map: "fk_role_permission_role")

  @@id([role_id, permission_id], map: "pk_role_has_permission")
  @@index([permission_id], map: "idx_role_permission_permission")
}

model skill {
  id                  Int                   @id(map: "pk_skill") @default(autoincrement())
  name                String                @unique(map: "uq_skill_name") @db.VarChar(50)
  description         String?               @db.VarChar(255)
  project_has_skill   project_has_skill[]
