}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model staff_has_job_title_history {
  id           Int       @default(autoincrement())
  staff_id     Int
  job_title_id Int
  start_date   DateTime  @default(dbgenerated("CURRENT_DATE")) @db.Date
  end_date     DateTime? @db.Date
  staff        staff     @relation(fields: [staff_id], references: [id], onDelete: Cascade, map: "fk_job_hist_staff")
  job_title    job_title @relation(fields: [job_title_id], references: [id], map: "fk_job_hist_title")

  @@id([id, staff_id, job_title_id], map: "pk_staff_has_job_title_history")
  @@index([staff_id], map: "idx_job_hist_staff")
  @@index([job_title_id], map: "idx_job_hist_title")
}

model status {
  id                                                             Int                   @id(map: "pk_status") @default(autoincrement())
  table_name                                                     String                @db.VarChar(50)
  status_name                                                    String                @db.VarChar(50)
  allowed_transitions_allowed_transitions_from_status_idTostatus allowed_transitions[] @relation("allowed_transitions_from_status_idTostatus")
  allowed_transitions_allowed_transitions_to_status_idTostatus   allowed_transitions[] @relation("allowed_transitions_to_status_idTostatus")
  project_has_status                                             project_has_status[]
  project_task                                                   project_task[]

  @@unique([table_name, status_name], map: "uq_status_combination")
}

model telephone {
  id       Int    @id(map: "pk_telephone") @default(autoincrement())
  number   String @db.VarChar(20)
  actor_id Int
  actor    actor  @relation(fields: [actor_id], references: [id], onDelete: Cascade, map: "fk_telephone_actor")

  @@index([actor_id], map: "idx_telephone_actor")
}

model users {
  id        Int         @id(map: "pk_users") @default(autoincrement())
  actor_id  Int         @unique(map: "uq_users_actor")
  role_id   Int
  nickname  String      @unique(map: "uq_users_nickname") @db.VarChar(50)
  password  String      @db.VarChar(255)
  audit_log audit_log[]
  actor     actor       @relation(fields: [actor_id], references: [id], onDelete: Cascade, map: "fk_users_actor")
  role      role        @relation(fields: [role_id], references: [id], map: "fk_users_role")

  @@index([role_id], map: "idx_users_role")
}

