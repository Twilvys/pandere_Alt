  salary                      Decimal                       @default(0.0000) @db.Decimal(19, 4)
  hiring_date                 DateTime                      @default(dbgenerated("CURRENT_DATE")) @db.Date
  actor                       actor                         @relation(fields: [actor_id], references: [id], onDelete: Cascade, map: "fk_staff_actor")
