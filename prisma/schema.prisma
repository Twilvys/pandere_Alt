}

model volunteer_has_skill {
  volunteer_id Int
  skill_id     Int
  skill        skill     @relation(fields: [skill_id], references: [id], onDelete: Cascade, map: "fk_vol_skills_skill")
  volunteer    volunteer @relation(fields: [volunteer_id], references: [id], onDelete: Cascade, map: "fk_vol_skills_volunteer")

  @@id([volunteer_id, skill_id], map: "pk_volunteer_has_skill")
